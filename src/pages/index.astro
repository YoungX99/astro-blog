---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { HOME_PROFILE, SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const recentPosts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const now = new Date();
const fallbackTime = new Intl.DateTimeFormat("en-US", {
  hour: "2-digit",
  minute: "2-digit",
}).format(now);
const fallbackDate = new Intl.DateTimeFormat("en-US", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(now);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main
      id="main-content"
      class="element-container flex items-center justify-center"
    >
      <section class="mx-auto">
        <div
          class="grid gap-6 lg:grid-cols-[minmax(300px,1fr)_minmax(0,1.45fr)]"
        >
          <aside class="flex flex-col justify-center">
            <div class="space-y-6">
              <div
                class="inline-flex h-14 w-14 items-center justify-center rounded-full border border-cyan-200/30 bg-cyan-300/18 text-lg font-semibold text-cyan-100"
              >
                JR
              </div>
              <div class="space-y-6">
                <h1
                  class="m-0 text-4xl font-bold tracking-tight text-zinc-50 sm:text-5xl"
                >
                  {HOME_PROFILE.name}
                </h1>
                <p class="m-0 mt-4 max-w-[42ch] text-zinc-300">
                  {HOME_PROFILE.intro}
                </p>
              </div>
              <div class="flex flex-wrap gap-3">
                <a
                  href="/blog"
                  class="inline-flex min-h-11 items-center rounded-xl border border-cyan-300/40 bg-cyan-300/12 px-4 text-sm font-semibold text-cyan-100 transition-colors duration-200 hover:bg-cyan-300/22 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300"
                >
                  Read Blog
                </a>
                <a
                  href="/about"
                  class="inline-flex min-h-11 items-center rounded-xl border border-zinc-700 bg-zinc-900/80 px-4 text-sm font-semibold text-zinc-200 transition-colors duration-200 hover:border-zinc-500 hover:bg-zinc-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300"
                >
                  About Me
                </a>
              </div>
            </div>
          </aside>

          <section
            class="grid grid-cols-2 gap-3.5 xl:grid-cols-4 xl:grid-rows-3"
          >
            <!-- R1C1: Role (square) -->
            <article
              class="widget flex aspect-square flex-col justify-between border border-cyan-400/12 bg-linear-to-br from-cyan-500/20 via-cyan-600/10 to-transparent"
            >
              <div class="widget-icon bg-cyan-400/15">
                <Icon name="lucide:user" class="h-4.5 w-4.5 text-cyan-300" />
              </div>
              <div>
                <p class="widget-label">{HOME_PROFILE.roleLabel}</p>
                <p class="widget-value mt-1">{HOME_PROFILE.roleValue}</p>
              </div>
            </article>

            <!-- R1C2: Location (square) -->
            <article
              class="widget flex aspect-square flex-col justify-between border border-emerald-400/12 bg-linear-to-br from-emerald-500/20 via-emerald-600/10 to-transparent"
            >
              <div class="widget-icon bg-emerald-400/15">
                <Icon
                  name="lucide:map-pin"
                  class="h-4.5 w-4.5 text-emerald-300"
                />
              </div>
              <div>
                <p class="widget-label">{HOME_PROFILE.locationLabel}</p>
                <p class="widget-value mt-1">{HOME_PROFILE.locationValue}</p>
              </div>
            </article>

            <!-- R1-2 C3-4: Recent Posts (tall, spans 2 cols × 2 rows) -->
            <aside
              class="widget-glass col-span-2 flex flex-col xl:col-start-3 xl:row-span-2 xl:row-start-1"
            >
              <p class="widget-label">{`Recent Posts`}</p>
              <ul class="mt-3.5 flex flex-1 list-none flex-col gap-1.5 p-0">
                {
                  recentPosts.map((post) => (
                    <li>
                      <a
                        href={`/blog/${post.id}/`}
                        class="flex cursor-pointer items-center gap-3 rounded-[12px] bg-white/4 px-3 py-2.5 text-sm text-white/70 no-underline transition-all duration-200 hover:bg-white/8 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300"
                      >
                        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white/6">
                          <Icon
                            name="lucide:book-open"
                            class="h-3.5 w-3.5 text-white/50"
                          />
                        </span>
                        <span class="flex flex-1 flex-col gap-0.5 overflow-hidden">
                          <span class="truncate text-[13px] leading-tight font-medium text-white/90">
                            {post.data.title}
                          </span>
                          <span class="text-[11px] text-white/40">
                            {post.data.pubDate.toLocaleDateString("en-US", {
                              month: "short",
                              day: "numeric",
                            })}
                          </span>
                        </span>
                        <Icon
                          name="lucide:chevron-right"
                          class="h-3.5 w-3.5 shrink-0 text-white/25"
                        />
                      </a>
                    </li>
                  ))
                }
              </ul>
            </aside>

            <!-- R2 C1-2: Instagram (wide, spans 2 cols) -->
            <a
              href="https://instagram.com/"
              target="_blank"
              rel="noreferrer"
              class="widget widget-interactive group col-span-2 flex flex-col justify-between border border-fuchsia-400/15 bg-linear-to-r from-fuchsia-500/22 via-pink-500/16 to-orange-400/18 text-white no-underline xl:col-start-1 xl:row-start-2"
            >
              <div class="flex items-center justify-between">
                <div class="widget-icon bg-white/10">
                  <Icon
                    name="simple-icons:instagram"
                    class="h-4.5 w-4.5 text-white/90"
                  />
                </div>
                <Icon
                  name="lucide:arrow-up-right"
                  class="h-4 w-4 text-white/40 transition-transform duration-200 group-hover:translate-x-0.5"
                />
              </div>
              <div>
                <p class="widget-label">{HOME_PROFILE.instagramLabel}</p>
                <p class="widget-value mt-1">{HOME_PROFILE.instagramValue}</p>
              </div>
            </a>

            <!-- R3C1: Local Time (square) -->
            <article
              class="widget-glass flex aspect-square flex-col justify-between xl:col-start-1 xl:row-start-3"
            >
              <p class="widget-label">Local Time</p>
              <p
                id="home-time"
                class="m-0 mt-2 text-[32px] leading-none font-semibold tracking-tight text-white tabular-nums"
              >
                {fallbackTime}
              </p>
            </article>

            <!-- R3C2: Current Date (square) -->
            <article
              class="widget-glass flex aspect-square flex-col justify-between xl:col-start-2 xl:row-start-3"
            >
              <p class="widget-label">Current Date</p>
              <p
                id="home-date"
                class="m-0 mt-1.5 text-sm leading-snug font-medium text-white/80"
              >
                {fallbackDate}
              </p>
              <div class="mt-auto border-t border-white/6 pt-3">
                <p class="widget-label text-cyan-300/70">
                  {HOME_PROFILE.reminderLabel}
                </p>
                <p class="m-0 mt-1 text-[13px] leading-snug text-white/60">
                  {HOME_PROFILE.reminderValue}
                </p>
              </div>
            </article>

            <!-- R3 C3-4: Photos (wide, spans 2 cols) -->
            <a
              href="/photo"
              class="widget widget-interactive group col-span-2 flex flex-col justify-between border border-blue-400/15 bg-linear-to-br from-blue-500/22 via-cyan-500/14 to-transparent text-white no-underline xl:col-start-3 xl:row-start-3"
            >
              <div class="flex items-center justify-between">
                <div class="widget-icon bg-blue-400/15">
                  <Icon name="lucide:image" class="h-4.5 w-4.5 text-blue-300" />
                </div>
                <Icon
                  name="lucide:arrow-up-right"
                  class="h-4 w-4 text-white/40 transition-transform duration-200 group-hover:translate-x-0.5"
                />
              </div>
              <div>
                <p class="widget-label">{HOME_PROFILE.photosLabel}</p>
                <p class="widget-value mt-1">{HOME_PROFILE.photosValue}</p>
              </div>
            </a>
          </section>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<script is:inline>
  (() => {
    const setupClock = () => {
      const timeEl = document.getElementById("home-time");
      const dateEl = document.getElementById("home-date");
      if (!timeEl || !dateEl) return;

      const updateClock = () => {
        const now = new Date();
        timeEl.textContent = new Intl.DateTimeFormat(undefined, {
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
        }).format(now);
        dateEl.textContent = new Intl.DateTimeFormat(undefined, {
          weekday: "long",
          year: "numeric",
          month: "long",
          day: "numeric",
        }).format(now);
      };

      updateClock();

      if (window.__homeClockTimer)
        window.clearInterval(window.__homeClockTimer);
      window.__homeClockTimer = window.setInterval(updateClock, 1000);
    };

    setupClock();
    document.addEventListener("astro:page-load", setupClock);
    document.addEventListener("astro:before-swap", () => {
      if (window.__homeClockTimer) {
        window.clearInterval(window.__homeClockTimer);
        window.__homeClockTimer = undefined;
      }
    });
  })();
</script>
