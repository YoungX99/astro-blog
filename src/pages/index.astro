---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { HOME_PROFILE, SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const recentPosts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const now = new Date();
const fallbackTime = new Intl.DateTimeFormat("en-US", {
  hour: "2-digit",
  minute: "2-digit",
}).format(now);
const fallbackDate = new Intl.DateTimeFormat("en-US", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(now);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main
      id="main-content"
      class="element-container flex items-center justify-center"
    >
      <section class="mx-auto">
        <div
          class="grid gap-6 lg:grid-cols-[minmax(300px,1fr)_minmax(0,1.45fr)]"
        >
          <aside class="flex flex-col justify-center">
            <div class="space-y-7">
              <div
                class="inline-flex h-14 w-14 items-center justify-center rounded-full border border-cyan-200/30 bg-cyan-300/18 text-lg font-semibold text-cyan-100"
              >
                JR
              </div>
              <div class="space-y-3">
                <p
                  class="m-0 text-sm tracking-[0.28em] text-zinc-400 uppercase"
                >
                  {HOME_PROFILE.greeting}
                </p>
                <h1
                  class="m-0 text-4xl font-bold tracking-tight text-zinc-50 sm:text-5xl"
                >
                  {HOME_PROFILE.name}
                </h1>
                <p class="m-0 max-w-[42ch] text-zinc-300">
                  {HOME_PROFILE.intro}
                </p>
              </div>
              <div class="flex flex-wrap gap-3">
                <a
                  href="/blog"
                  class="inline-flex min-h-11 items-center rounded-xl border border-cyan-300/40 bg-cyan-300/12 px-4 py-2 text-sm font-semibold text-cyan-100 transition-colors duration-200 hover:bg-cyan-300/22 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300"
                >
                  Read Blog
                </a>
                <a
                  href="/about"
                  class="inline-flex min-h-11 items-center rounded-xl border border-zinc-700 bg-zinc-900/80 px-4 py-2 text-sm font-semibold text-zinc-200 transition-colors duration-200 hover:border-zinc-500 hover:bg-zinc-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300"
                >
                  About Me
                </a>
              </div>
            </div>
          </aside>

          <section
            class="grid grid-cols-2 gap-3.5 xl:auto-rows-[minmax(128px,auto)] xl:grid-cols-3"
          >
            <!-- Role -->
            <article
              class="widget flex flex-col justify-between border border-cyan-400/[0.12] bg-gradient-to-br from-cyan-500/20 via-cyan-600/10 to-transparent"
            >
              <div class="widget-icon bg-cyan-400/15">
                <svg
                  viewBox="0 0 24 24"
                  class="h-4.5 w-4.5 text-cyan-300"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                  <circle cx="12" cy="7" r="4"></circle>
                </svg>
              </div>
              <div>
                <p class="widget-label">{HOME_PROFILE.roleLabel}</p>
                <p class="widget-value mt-1">{HOME_PROFILE.roleValue}</p>
              </div>
            </article>

            <!-- Location -->
            <article
              class="widget flex flex-col justify-between border border-emerald-400/[0.12] bg-gradient-to-br from-emerald-500/20 via-emerald-600/10 to-transparent"
            >
              <div class="widget-icon bg-emerald-400/15">
                <svg
                  viewBox="0 0 24 24"
                  class="h-4.5 w-4.5 text-emerald-300"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <path
                    d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"
                  ></path>
                  <circle cx="12" cy="9" r="2.5"></circle>
                </svg>
              </div>
              <div>
                <p class="widget-label">{HOME_PROFILE.locationLabel}</p>
                <p class="widget-value mt-1">{HOME_PROFILE.locationValue}</p>
              </div>
            </article>

            <!-- Instagram -->
            <a
              href="https://instagram.com/"
              target="_blank"
              rel="noreferrer"
              class="widget widget-interactive group col-span-2 flex min-h-[128px] flex-col justify-between border border-fuchsia-400/[0.15] bg-gradient-to-r from-fuchsia-500/22 via-pink-500/16 to-orange-400/18 text-white no-underline xl:col-span-2 xl:col-start-1 xl:row-start-2"
            >
              <div class="flex items-center justify-between">
                <div class="widget-icon bg-white/10">
                  <svg
                    viewBox="0 0 24 24"
                    class="h-4.5 w-4.5 text-white/90"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                  >
                    <rect x="3.5" y="3.5" width="17" height="17" rx="5"></rect>
                    <circle cx="12" cy="12" r="3.7"></circle>
                    <circle
                      cx="17.3"
                      cy="6.8"
                      r="0.9"
                      fill="currentColor"
                      stroke="none"></circle>
                  </svg>
                </div>
                <svg
                  viewBox="0 0 24 24"
                  class="h-4 w-4 text-white/40 transition-transform duration-200 group-hover:translate-x-0.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M7 17l9.2-9.2M17 17V7H7"></path>
                </svg>
              </div>
              <div>
                <p class="widget-label">{HOME_PROFILE.instagramLabel}</p>
                <p class="widget-value mt-1">{HOME_PROFILE.instagramValue}</p>
              </div>
            </a>

            <!-- Recent Posts -->
            <aside
              class="widget-glass col-span-2 flex flex-col xl:col-span-1 xl:col-start-3 xl:row-span-2 xl:row-start-1"
            >
              <p class="widget-label">{`Recent Posts`}</p>
              <ul class="mt-3.5 flex flex-1 list-none flex-col gap-1.5 p-0">
                {
                  recentPosts.map((post) => (
                    <li>
                      <a
                        href={`/blog/${post.id}/`}
                        class="flex cursor-pointer items-center gap-3 rounded-[12px] bg-white/[0.04] px-3 py-2.5 text-sm text-white/70 no-underline transition-all duration-200 hover:bg-white/[0.08] hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300"
                      >
                        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white/[0.06]">
                          <svg
                            viewBox="0 0 24 24"
                            class="h-3.5 w-3.5 text-white/50"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
                          </svg>
                        </span>
                        <span class="flex flex-1 flex-col gap-0.5 overflow-hidden">
                          <span class="truncate text-[13px] leading-tight font-medium text-white/90">
                            {post.data.title}
                          </span>
                          <span class="text-[11px] text-white/40">
                            {post.data.pubDate.toLocaleDateString("en-US", {
                              month: "short",
                              day: "numeric",
                            })}
                          </span>
                        </span>
                        <svg
                          viewBox="0 0 24 24"
                          class="h-3.5 w-3.5 shrink-0 text-white/25"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2.5"
                        >
                          <path d="M9 18l6-6-6-6" />
                        </svg>
                      </a>
                    </li>
                  ))
                }
              </ul>
            </aside>

            <!-- Local Time -->
            <article
              class="widget-glass flex flex-col justify-between xl:col-start-1 xl:row-start-3"
            >
              <p class="widget-label">Local Time</p>
              <p
                id="home-time"
                class="m-0 mt-2 text-[32px] leading-none font-semibold tracking-tight text-white tabular-nums"
              >
                {fallbackTime}
              </p>
            </article>

            <!-- Date + Reminder -->
            <article
              class="widget-glass flex flex-col xl:col-start-2 xl:row-start-3"
            >
              <p class="widget-label">Current Date</p>
              <p
                id="home-date"
                class="m-0 mt-1.5 text-sm leading-snug font-medium text-white/80"
              >
                {fallbackDate}
              </p>
              <div class="mt-auto border-t border-white/[0.06] pt-3">
                <p class="widget-label text-cyan-300/70">
                  {HOME_PROFILE.reminderLabel}
                </p>
                <p class="m-0 mt-1 text-[13px] leading-snug text-white/60">
                  {HOME_PROFILE.reminderValue}
                </p>
              </div>
            </article>

            <!-- Photos -->
            <a
              href="/photo"
              class="widget widget-interactive group col-span-2 flex min-h-[128px] flex-col justify-between border border-blue-400/[0.15] bg-gradient-to-br from-blue-500/22 via-cyan-500/14 to-transparent text-white no-underline xl:col-span-1 xl:col-start-3 xl:row-start-3"
            >
              <div class="flex items-center justify-between">
                <div class="widget-icon bg-blue-400/15">
                  <svg
                    viewBox="0 0 24 24"
                    class="h-4.5 w-4.5 text-blue-300"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                  >
                    <rect x="3.5" y="4.5" width="17" height="15" rx="2.2"
                    ></rect>
                    <circle cx="9" cy="10" r="1.8"></circle>
                    <path d="M20 15l-4.4-4.2a1.4 1.4 0 0 0-1.9 0L8 16.5"></path>
                  </svg>
                </div>
                <svg
                  viewBox="0 0 24 24"
                  class="h-4 w-4 text-white/40 transition-transform duration-200 group-hover:translate-x-0.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M7 17l9.2-9.2M17 17V7H7"></path>
                </svg>
              </div>
              <div>
                <p class="widget-label">{HOME_PROFILE.photosLabel}</p>
                <p class="widget-value mt-1">{HOME_PROFILE.photosValue}</p>
              </div>
            </a>
          </section>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<script is:inline>
  (() => {
    const setupClock = () => {
      const timeEl = document.getElementById("home-time");
      const dateEl = document.getElementById("home-date");
      if (!timeEl || !dateEl) return;

      const updateClock = () => {
        const now = new Date();
        timeEl.textContent = new Intl.DateTimeFormat(undefined, {
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
        }).format(now);
        dateEl.textContent = new Intl.DateTimeFormat(undefined, {
          weekday: "long",
          year: "numeric",
          month: "long",
          day: "numeric",
        }).format(now);
      };

      updateClock();

      if (window.__homeClockTimer)
        window.clearInterval(window.__homeClockTimer);
      window.__homeClockTimer = window.setInterval(updateClock, 1000);
    };

    setupClock();
    document.addEventListener("astro:page-load", setupClock);
    document.addEventListener("astro:before-swap", () => {
      if (window.__homeClockTimer) {
        window.clearInterval(window.__homeClockTimer);
        window.__homeClockTimer = undefined;
      }
    });
  })();
</script>
