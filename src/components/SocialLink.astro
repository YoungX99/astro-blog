---
import { Icon } from "astro-icon/components";

interface Props {
  href: string;
  label: string;
  icon: "mastodon" | "twitter" | "github";
  variant?: "header" | "footer";
}

const { href, label, icon, variant = "footer" } = Astro.props;

const iconMap = {
  mastodon: "simple-icons:mastodon",
  twitter: "simple-icons:x",
  github: "simple-icons:github",
} as const;

const variantClasses = {
  header: "social-link-header",
  footer: "social-link-footer",
};
---

<a href={href} target="_blank" rel="noreferrer" class={variantClasses[variant]}>
  <span class="sr-only">{label}</span>
  <Icon name={iconMap[icon]} class="h-5 w-5" aria-hidden="true" />
</a>
