---
import SocialLink from "./SocialLink.astro";

const today = new Date();
---

<footer class="px-4 pb-10 pt-10 sm:px-6">
  <div
    class="mx-auto flex max-w-6xl flex-col items-center gap-4 rounded-2xl border border-zinc-800/80 bg-zinc-950/65 px-6 py-6 text-center text-zinc-400 shadow-[0_12px_40px_rgba(0,0,0,0.4)] backdrop-blur"
  >
    <p class="m-0 text-sm">
      &copy; {today.getFullYear()} Your name here. All rights reserved.
    </p>
    <div class="flex justify-center gap-2">
      <SocialLink
        href="https://m.webtoo.ls/@astro"
        label="Follow Astro on Mastodon"
        icon="mastodon"
        variant="footer"
      />
      <SocialLink
        href="https://twitter.com/astrodotbuild"
        label="Follow Astro on Twitter"
        icon="twitter"
        variant="footer"
      />
      <SocialLink
        href="https://github.com/withastro/astro"
        label="Go to Astro's GitHub repo"
        icon="github"
        variant="footer"
      />
    </div>
  </div>
</footer>
